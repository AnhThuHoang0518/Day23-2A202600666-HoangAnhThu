# Copy this file to .env, then fill in your real keys.
# Do not commit .env.

# -----------------------------------------------------------------------------
# LLM provider - OpenAI is recommended for this submission
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional alternative providers. Leave commented unless you intentionally use them.
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# LangSmith tracing - optional observability
# -----------------------------------------------------------------------------
# Set LANGSMITH_TRACING=true only when LANGSMITH_API_KEY is filled.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=phase2-track3-day8-langgraph-lab

# Backwards-compatible LangChain tracing variable names.
# These are supported by the app and mapped to/from LANGSMITH_* when present.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=phase2-track3-day8-langgraph-lab

# -----------------------------------------------------------------------------
# Human-in-the-loop approval
# -----------------------------------------------------------------------------
# Default behavior is mock approval, so tests and scenario runs can complete offline.
# Set true only when you want real LangGraph interrupt behavior.
LANGGRAPH_INTERRUPT=false

# Optional mock approval controls: approve, reject, or edit.
APPROVAL_ACTION=approve
# APPROVAL_EDITED_ACTION=Review-only edited action text

# -----------------------------------------------------------------------------
# Persistence
# -----------------------------------------------------------------------------
# memory: fast local/default checkpointer
# sqlite: persistent local checkpoint database under outputs/
# none: no checkpointer
CHECKPOINTER=memory
# DATABASE_URL=outputs/langgraph_checkpoints.sqlite

# -----------------------------------------------------------------------------
# Runtime logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
